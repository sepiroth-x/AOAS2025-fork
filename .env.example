PORT=3000
RESEND_API_KEY=

# -------------------------------------------------------
# CORS / Origin security (required on dedicated servers)
# -------------------------------------------------------
# Set this to your site's canonical origin so the API
# accepts requests from your domain.
# Example: SITE_URL=https://aoa-services.com
SITE_URL=
# Or list multiple allowed origins comma-separated:
# CORS_ALLOWED_ORIGINS=https://aoa-services.com,https://www.aoa-services.com
CORS_ALLOWED_ORIGINS=

# Admin CRM auth (keep private, never expose in frontend)
ADMIN_USERNAME=admin
# Required. Set a strong password (8+ chars with letters and numbers).
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Admin
ADMIN_TOKEN_SECRET=
ADMIN_SELF_SIGNUP_ENABLED=false
# Vercel production notes:
# - Set ADMIN_PASSWORD to the real secret, not the placeholder value above.
# - ADMIN_USERNAME is optional; default aliases `admin` and `aoas` still work.
# - Redeploy after any environment-variable change.

# Supabase CRM backend
SUPABASE_URL=
# Required. Use Supabase Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: keep these only if you use them elsewhere outside the CRM admin backend.
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Route provider selection:
# auto | google | tomtom | osrm
ROUTE_API_PROVIDER=auto

# Optional traffic-aware providers:
GOOGLE_MAPS_API_KEY=
TOMTOM_API_KEY=

# Google Routes traffic model:
# pessimistic | best_guess | optimistic
ROUTE_GOOGLE_TRAFFIC_MODEL=pessimistic
